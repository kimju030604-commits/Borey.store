# Gateway mode: mock or live
BAKONG_MODE=mock

# Bakong Relay base URL
BAKONG_RELAY_BASE_URL=https://api.bakongrelay.com

# RBK token (required for live transaction-status checks)
BAKONG_API_TOKEN=

# Merchant display name
BAKONG_MERCHANT_NAME=Khem Sovanny

# Merchant account settings for /v1/generate_qr
BAKONG_BANK_ACCOUNT=
BAKONG_MERCHANT_CITY=Phnom Penh
BAKONG_PHONE_NUMBER=
BAKONG_STORE_LABEL=Borey Store
BAKONG_TERMINAL_LABEL=Checkout
BAKONG_CURRENCY=USD
BAKONG_STATIC_QR=false

# Optional static KHQR fallback string (real EMV string from your merchant account)
BAKONG_STATIC_KHQR=

# Local sqlite file
DATABASE_PATH=./gateway.db

# Server settings
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Telegram alert notifications
# Get token from @BotFather, chat_id is your group's numeric ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
